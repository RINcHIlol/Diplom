<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:diplom.ViewModels"
             mc:Ignorable="d"
             x:Class="diplom.Views.CreateTaskView"
             Foreground="Black"
             x:DataType="vm:CreateTaskViewModel">

    <UserControl.Resources>
        <vm:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>
    
    <StackPanel Spacing="10" Margin="10">
        <Button Content="Назад"
                Command="{Binding BackCommand}" Foreground="Black"/>

        <!-- 🔹 Выбор типа задачи -->
        <ComboBox ItemsSource="{Binding TaskTypes}"
                  SelectedItem="{Binding SelectedTask}"
                  IsVisible="{Binding IsEdit, Converter={StaticResource InverseBoolConverter}}">
            
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>

        </ComboBox>

        <!-- 🔹 Кнопка выбора -->
        <Button Content="Выбрать тип"
                Command="{Binding ChangeTypeCommand}" Foreground="Black"
                IsVisible="{Binding IsEdit, Converter={StaticResource InverseBoolConverter}}"/>

        <!-- 🔹 Динамический UI -->
        <ContentControl Content="{Binding Current}" Foreground="Black"/>

        <!-- 🔹 Сохранение -->
        <Button Content="Сохранить"
                Command="{Binding SaveCommand}" Foreground="Black"/>
        
        <TextBlock Text="{Binding Message}"
                   Foreground="Green"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
        
        <TextBlock Text="{Binding Error}"
                   Foreground="Red"
                   Margin="0,10,0,0"/>

    </StackPanel>
</UserControl>