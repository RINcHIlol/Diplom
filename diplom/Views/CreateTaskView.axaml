<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:diplom.ViewModels"
             xmlns:views="clr-namespace:diplom.Views"
             mc:Ignorable="d"
             x:Class="diplom.Views.CreateTaskView"
             Foreground="Black"
             x:DataType="vm:CreateTaskViewModel">

    <UserControl.Resources>
        <views:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>
    
    <StackPanel Spacing="10" Margin="10">
        <Button Content="Назад"
                Margin="0,0,10,0"
                Background="#D3D3D3"
                BorderBrush="Black"
                BorderThickness="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding BackCommand}" Foreground="Black"/>
        <ComboBox ItemsSource="{Binding TaskTypes}"
                  SelectedItem="{Binding SelectedTask}"
                  IsVisible="{Binding IsEdit, Converter={StaticResource InverseBoolConverter}}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Content="Выбрать тип"
                Command="{Binding ChangeTypeCommand}"
                Margin="0,0,10,0"
                Background="#D3D3D3"
                BorderBrush="Black"
                Foreground="Black"
                BorderThickness="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                IsVisible="{Binding IsEdit, Converter={StaticResource InverseBoolConverter}}"/>
        <ContentControl Content="{Binding Current}" Foreground="Black"/>
        <Button Content="Сохранить"
                Margin="0,0,10,0"
                Background="#D3D3D3"
                BorderBrush="Black"
                BorderThickness="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding SaveCommand}" Foreground="Black"/>
        <Button IsVisible="{Binding !IsEdit, Converter={StaticResource InverseBoolConverter}}"
                Content="Удалить задачу"
                Command="{Binding DeleteLessonCommand}"
                Margin="0,0,10,0"
                Background="#D3D3D3"
                BorderBrush="Black"
                BorderThickness="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Foreground="Black"/>
        <TextBlock Text="{Binding Message}"
                   Foreground="Green"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
        <TextBlock Text="{Binding Error}"
                   Foreground="Red"
                   Margin="0,10,0,0"/>
    </StackPanel>
</UserControl>