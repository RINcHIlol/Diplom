<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:diplom.ViewModels"
             xmlns:viewModels="clr-namespace:diplom.ViewModels"
             x:DataType="viewModels:ProfileViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="diplom.Views.ProfileView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#B0B0B0">
            <Button Content="← Назад"
                    Background="#D3D3D3"
                    BorderBrush="Black"
                    Foreground="Black"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Command="{Binding GoBackCommand}"/>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300" Spacing="10">
                <TextBlock Height="30" Text="{Binding Login, Mode=TwoWay}" />
                <TextBlock Height="30" Text="{Binding Email, Mode=TwoWay}" />
                <TextBlock Height="30" Text="{Binding Xp, Mode=TwoWay}" />
                <Border>
                    <ListBox ItemsSource="{Binding Courses}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <TextBlock Text="{Binding Title, Mode=TwoWay}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
