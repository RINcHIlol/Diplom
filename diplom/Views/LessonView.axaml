<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:diplom.ViewModels"
             xmlns:tasks="clr-namespace:diplom.ViewModels.Tasks"
             xmlns:views="clr-namespace:diplom.Views.Tasks"
             xmlns:views1="clr-namespace:diplom.Views"
             x:Class="diplom.Views.LessonView"
             Foreground="Black"
             x:DataType="vm:LessonViewModel">

    <UserControl.Resources>
        <views1:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid IsVisible="{Binding Tasks.Count, Converter={StaticResource NotZeroToBoolConverter}}"
              ColumnDefinitions="200,*" RowDefinitions="50,*">
            <Grid Grid.ColumnSpan="2" Background="#B0B0B0" ColumnDefinitions="*,*">
                <Button Grid.Column="0"
                        Content="← Назад"
                        Command="{Binding GoBackCommand}"
                        Margin="0,0,10,0"
                        Background="#D3D3D3"
                        BorderBrush="Black"
                        BorderThickness="1"
                        Foreground="Black"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding LessonName}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="Black"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Tasks}"
                     SelectedItem="{Binding CurrentTask, Mode=TwoWay}"
                     Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="tasks:TaskViewModel">
                        <Border Background="{Binding IsCorrect, Converter={StaticResource BoolToColorConverter}}"
                                Padding="5" Margin="2">
                            <TextBlock Text="{Binding DisplayIndex}" Foreground="Black"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10">
                <ContentControl Content="{Binding CurrentTask}" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding ResultText}"
                           FontSize="16"
                           Margin="0,0,0,10"
                           Foreground="Black"/>
                <Button Content="Ответить"
                        Command="{Binding SubmitCommand}"
                        Background="#D3D3D3"
                        BorderBrush="Black"
                        Foreground="Black"
                        BorderThickness="1"/>
            </StackPanel>

        </Grid>
        <StackPanel IsVisible="{Binding Tasks.Count, Converter={StaticResource ZeroToBoolConverter}}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="15">
            <TextBlock Text="🚧" FontSize="64" HorizontalAlignment="Center"/>
            <TextBlock Text="Урок в разработке"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Задания скоро появятся"
                       Foreground="Black"
                       Opacity="0.7"
                       HorizontalAlignment="Center"/>
            <Button Content="← Назад"
                    Margin="0,0,10,0"
                    Background="#D3D3D3"
                    BorderBrush="Black"
                    Foreground="Black"
                    BorderThickness="1"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding GoBackCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>