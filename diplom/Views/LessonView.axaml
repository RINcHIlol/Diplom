<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:diplom.ViewModels"
             xmlns:tasks="clr-namespace:diplom.ViewModels.Tasks"
             xmlns:views="clr-namespace:diplom.Views.Tasks"
             xmlns:views1="clr-namespace:diplom.Views"
             x:Class="diplom.Views.LessonView"
             Foreground="Black"
             x:DataType="vm:LessonViewModel">

    <UserControl.DataTemplates>
        <DataTemplate DataType="tasks:TextTaskViewModel">
            <views:TextTaskView Foreground="Black"/>
        </DataTemplate>

        <DataTemplate DataType="tasks:SingleChoiceTaskViewModel">
            <views:SingleChoiceTaskView Foreground="Black"/>
        </DataTemplate>

        <DataTemplate DataType="tasks:MultipleChoiceTaskViewModel">
            <views:MultipleChoiceTaskView Foreground="Black"/>
        </DataTemplate>
        
        <DataTemplate DataType="tasks:TextQuestionTaskViewModel">
            <views:TextQuestionTaskView Foreground="Black"/>
        </DataTemplate>
    </UserControl.DataTemplates>
    
    <UserControl.Resources>
        <views1:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="200,*" RowDefinitions="50,*">

        <!-- HEADER -->
        <Grid Grid.ColumnSpan="2" Background="#B0B0B0" ColumnDefinitions="*,*">
            <Button Grid.Column="0"
                    Content="← Назад"
                    Command="{Binding GoBackCommand}"
                    Margin="5"
                    Foreground="Black"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding LessonName}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Black"/>
        </Grid>

        <!-- SIDEBAR: список всех заданий -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Tasks}"
                 SelectedItem="{Binding CurrentTask, Mode=TwoWay}"
                 Margin="5">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="tasks:TaskViewModel">
                    <Border Background="{Binding IsCorrect, Converter={StaticResource BoolToColorConverter}}" Padding="5" Margin="2">
                        <TextBlock Text="{Binding Id}" Foreground="Black"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- CONTENT -->
        <StackPanel Grid.Column="1" Grid.Row="1" Margin="10">
            <ContentControl Content="{Binding CurrentTask}" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding ResultText}" FontSize="16" Margin="0,0,0,10" Foreground="Black"/>
            <Button Content="Ответить" Command="{Binding SubmitCommand}" Width="120" Foreground="Black"/>
        </StackPanel>

    </Grid>
</UserControl>