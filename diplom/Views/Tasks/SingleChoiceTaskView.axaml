<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:diplom.ViewModels.Tasks"
             x:Class="diplom.Views.Tasks.SingleChoiceTaskView"
             Foreground="Black"
             x:DataType="vm:SingleChoiceTaskViewModel">
    <StackPanel Margin="10" Spacing="10">
        <TextBlock Text="{Binding Question}" FontSize="16" FontWeight="Bold" Foreground="Black"/>
        <ItemsControl ItemsSource="{Binding Answers}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectableAnswer">
                    <RadioButton Content="{Binding Text}"
                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                 GroupName="answers"
                                 Foreground="Black"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>