<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:diplom.ViewModels.Tasks"
             x:Class="diplom.Views.Tasks.MathcingTaskView"
             Foreground="Black"
             x:DataType="vm:MatchingTaskViewModel">
    <StackPanel Margin="10" Spacing="10">
        <TextBlock Text="{Binding Question}"
                   FontSize="16"
                   FontWeight="Bold"/>
        <ItemsControl ItemsSource="{Binding Pairs}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:MatchingPair">
                    <Grid ColumnDefinitions="150,20,150"
                          VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Left.Text}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="→"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding RightItems}"
                                  SelectedItem="{Binding SelectedRight, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Text}"
                                  VerticalAlignment="Center"
                                  Height="30"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>